<div class="flex-row space-y-4">
  <h1 class="text-4xl font-bold">Dashboard</h1>

  <div class="flex flex-col space-y-2">
    <h2 class="text-2xl font-medium">Projects</h2>

    <%= render @projects %>

    <%= link_to "New Project", new_project_path, class: "btn" %>
  </div>

  <%= link_to "Logout",
  session_path,
  data: {
    turbo_method: :delete,
    turbo_confirm: "Are you sure?",
  },
  class: "btn" %>
</div>
